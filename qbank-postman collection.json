					],
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Accept", "value": "application/json" },
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"subject_id\": {{subject_id}},\n    \"topic_id\": {{topic_id}},\n    \"type\": \"mcq\",\n    \"difficulty\": \"medium\",\n    \"question_text\": \"Which of Newton's laws explains why a ball rolling on a surface eventually stops?\",\n    \"marks\": 2,\n    \"negative_marks\": 0.5,\n    \"time_limit_sec\": 60,\n    \"options\": [\n        {\n            \"option_text\": \"First Law (Inertia)\",\n            \"is_correct\": false,\n            \"sort_order\": 0,\n            \"explanation\": \"First law is about inertia, not friction\"\n        },\n        {\n            \"option_text\": \"Second Law (F=ma)\",\n            \"is_correct\": true,\n            \"sort_order\": 1,\n            \"explanation\": \"Friction acts as unbalanced force, F=ma decelerates the ball\"\n        },\n        {\n            \"option_text\": \"Third Law (Action-Reaction)\",\n            \"is_correct\": false,\n            \"sort_order\": 2,\n            \"explanation\": \"Third law describes paired forces, not deceleration\"\n        },\n        {\n            \"option_text\": \"Law of Universal Gravitation\",\n            \"is_correct\": false,\n            \"sort_order\": 3,\n            \"explanation\": \"Gravitation pulls downward, doesn't stop horizontal motion\"\n        }\n    ],\n    \"explanation\": \"Friction is an unbalanced force. By Newton's second law F=ma, this net force decelerates the ball until velocity reaches zero.\",\n    \"solution_approach\": \"Step 1: Identify forces acting on the ball (gravity, normal, friction)\\nStep 2: Friction is unbalanced in horizontal direction\\nStep 3: Apply F=ma → a = friction/mass (negative)\\nStep 4: Ball decelerates to v=0\",\n    \"tags\": [\"neet-2025\", \"mechanics\", \"pyq\"],\n    \"language\": \"en\",\n    \"source\": \"NCERT Class 11, Ch 5\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/v1/questions",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "questions"]
						}
					}
				},
				{
					"name": "Create Multi-Select",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
