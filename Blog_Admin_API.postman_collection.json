              "raw": "{\n  \"title\": \"10 Tips for Better Learning\",\n  \"slug\": \"10-tips-for-better-learning\",\n  \"excerpt\": \"A short description shown on listing pages.\",\n  \"content\": \"<h2>Introduction</h2><p>Learning is a lifelong journey...</p>\",\n  \"category_id\": 1,\n  \"tags\": [\"education\", \"tips\", \"learning\"],\n  \"featured_image\": \"https://example.com/images/blog-cover.jpg\",\n  \"featured_image_alt\": \"Students studying together\",\n  \"status\": \"published\",\n  \"published_at\": \"2026-03-24 10:00:00\",\n  \"is_featured\": true,\n  \"allow_comments\": true,\n  \"meta_title\": \"10 Tips for Better Learning\",\n  \"meta_description\": \"Discover 10 proven strategies to improve your learning efficiency and retain information better.\",\n  \"meta_keywords\": \"learning tips, study strategies, education\",\n  \"og_title\": \"10 Tips for Better Learning\",\n  \"og_description\": \"Discover 10 proven strategies to improve your learning efficiency.\",\n  \"og_image\": \"https://example.com/images/og-cover.jpg\",\n  \"canonical_url\": \"https://yoursite.com/blogs/10-tips-for-better-learning\",\n  \"robots\": \"index,follow\",\n  \"schema_markup\": null\n}"
            },
            "url": {
