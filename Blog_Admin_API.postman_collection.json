{
  "info": {
    "name": "Blog Admin API",
    "_postman_id": "blog-admin-api-collection",
    "description": "Full Blog Module — Admin & Public API endpoints.\n\nSetup:\n1. Run **Auth / Login** first\n2. The token is saved automatically to {{token}} via the login test script\n3. All admin requests use {{token}} in the Bearer header automatically",
    "schema": "https://schema.postman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://127.0.0.1:8000/api", "type": "string" },
    { "key": "token",    "value": "", "type": "string" }
  ],
  "item": [

    {
      "name": "🔐 Auth",
      "item": [
        {
          "name": "Login (get token)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.token) {",
                  "  pm.collectionVariables.set('token', json.token);",
                  "  console.log('Token saved:', json.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept",       "value": "application/json" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@example.com\",\n  \"password\": \"password\"\n}"
            },
            "url": { "raw": "{{base_url}}/login", "host": ["{{base_url}}"], "path": ["login"] }
          }
        },
        {
          "name": "Get Authenticated User",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept",        "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{base_url}}/user", "host": ["{{base_url}}"], "path": ["user"] }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept",        "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{base_url}}/logout", "host": ["{{base_url}}"], "path": ["logout"] }
          }
        }
      ]
    },

    {
      "name": "📝 Admin — Blogs",
      "item": [
        {
          "name": "List All Blogs",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept",        "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/admin/blogs?page=1&per_page=15&status=published&search=&sort=latest&featured=false&with_trashed=false",
              "host": ["{{base_url}}"],
              "path": ["admin", "blogs"],
              "query": [
                { "key": "page",         "value": "1",         "description": "Page number" },
                { "key": "per_page",     "value": "15",        "description": "Items per page (max 100)" },
