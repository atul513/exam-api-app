                { "key": "search",       "value": "",          "description": "Search in title, excerpt, content", "disabled": true },
                { "key": "sort",         "value": "latest",    "description": "latest | oldest | popular" },
                { "key": "category_id",  "value": "1",         "description": "Filter by category ID", "disabled": true },
                { "key": "author_id",    "value": "1",         "description": "Filter by author user ID", "disabled": true },
                { "key": "featured",     "value": "true",      "description": "Show featured only", "disabled": true },
                { "key": "with_trashed", "value": "true",      "description": "Include soft-deleted blogs", "disabled": true }
              ]
            }
          }
        },
