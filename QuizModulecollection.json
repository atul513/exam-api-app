		{
			"name": "🎯 Student — Attempt Flow",
			"description": "Full student flow: check access → start → answer questions → submit → view result.\n\nRun these in order to simulate a complete quiz attempt.",
			"item": [
				{
					"name": "1. Check Access",
					"event": [{
						"listen": "test",
						"script": {
							"type": "text/javascript",
							"exec": [
								"var d = pm.response.json();",
								"pm.test('Status 200', () => pm.response.to.have.status(200));",
								"console.log('Access allowed: ' + d.allowed + ' — ' + d.reason);"
							]
						}
					}],
					"request": {
						"method": "GET",
						"header": [{ "key": "Accept", "value": "application/json" }],
						"url": {
							"raw": "{{base_url}}/api/v1/quizzes/{{quiz_id}}/check-access",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "quizzes", "{{quiz_id}}", "check-access"]
						}
					}
				},
				{
					"name": "2. Start Quiz (creates attempt)",
					"event": [{
						"listen": "test",
						"script": {
							"type": "text/javascript",
							"exec": [
								"var d = pm.response.json();",
								"if (d.data && d.data.attempt_id) {",
								"    pm.collectionVariables.set('attempt_id', d.data.attempt_id);",
								"    console.log('attempt_id set to: ' + d.data.attempt_id);",
								"    console.log('Remaining seconds: ' + d.data.remaining_seconds);",
								"    console.log('Total questions: ' + d.data.total_questions);",
								"}",
								"pm.test('Status 201 or 200', () => {",
								"    pm.expect([200, 201]).to.include(pm.response.code);",
								"});"
							]
						}
					}],
					"request": {
						"method": "POST",
						"header": [{ "key": "Accept", "value": "application/json" }],
						"url": {
							"raw": "{{base_url}}/api/v1/quizzes/{{quiz_id}}/start",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "quizzes", "{{quiz_id}}", "start"]
						}
					}
				},
				{
